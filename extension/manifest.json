{
  "manifest_version": 3,
  "name": "暖暖小窝",
  "version": "1.1.3",
  "description": "局域网好友协作工具 - 端到端加密聊天、待办、午餐随机推荐",
  "permissions": ["storage", "notifications", "alarms"],
  "host_permissions": ["ws://*:*/*", "http://*:*/*"],
  "update_url": "https://p8swwgvv2n-blip.github.io/nnxiaowo/extension/updates.xml",
  "action": {
    "default_popup": "popup.html",
    "default_title": "暖暖小窝",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
